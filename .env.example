# channel-analytics 环境变量模板
#
# 使用方法(任何 clone 用户):
#   1. cp .env.example .env
#   2. python -m channel_analytics.cli init-secrets    # 自动生成 3 个 secret 写进 .env
#   3. 按需填 DB_*, RPA_* 字段
#   4. 启动后端: uvicorn channel_analytics.api.app:app
#
# ⚠️ 占位符 "GENERATE-ON-FIRST-RUN" 表示启动时由 init-secrets 自动生成。
#    任何以这个字符串开头的值都不能直接用于生产,需先执行 init-secrets。

# ---------- 安全密钥(启动时自动生成) ----------
SESSION_SECRET=GENERATE-ON-FIRST-RUN
JWT_SECRET=GENERATE-ON-FIRST-RUN
APP_SECRET=GENERATE-ON-FIRST-RUN

# ---------- 数据库 ----------
# 默认 SQLite(零配置,适合 first-run);生产请用 MySQL/PostgreSQL 并填下方字段
DATABASE_URL=sqlite:///./data/dev.db

# MySQL 示例(取消注释并填值):
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/channel_analytics?charset=utf8mb4
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=replace_me
# DB_PASSWORD=replace_me
# DB_NAME=channel_analytics
# DB_CHARSET=utf8mb4

# ---------- 业务配置 ----------
APP_ENV=development   # development | production
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Shanghai

# ---------- RPA 通用配置(零厂商绑定) ----------
# 用户通过 RPA_ADAPTER 指定自己的 adapter 类(从已安装的 entry_points 自动发现)
RPA_ADAPTER=channel_analytics.rpa.adapters.example_minimal:ExampleMinimalAdapter
RPA_TARGET_URL=
RPA_USERNAME=
RPA_PASSWORD=
RPA_DOWNLOAD_DIR=./data/rpa_downloads
RPA_HEADLESS=true
RPA_TIMEOUT_MS=30000
RPA_SLOW_MO_MS=300

# ---------- 邮件通知(可选) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
